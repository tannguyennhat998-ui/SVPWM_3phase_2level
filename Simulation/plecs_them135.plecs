        Value         ""
        Show          off
      }
      Parameter {
        Variable      "OutputFcn"
        Value         "#include<math.h>\n"
"\n"
"double va=InputSignal(0, 0),vb=InputSignal(0, 1),vc=InputSignal(0, 2);\n"
"double pi=3.1415926535897932384626433832795;\n"
"double n,phi,theta;\n"
"double valpha,vbeta;\n"
"double tx,ty,tz;\n"
"double tx1,ty1,tz1,x,y;\n"
"double vao,vbo,vco;\n"
"double vau,vad,vbu,vbd,vcu,vcd;\n"
"double a,b,m;\n"
"\n"
"valpha=va-(vb/2)-(vc/2);\n"
"vbeta=(sqrt(3)/2)*(vb-vc);\n"
"theta=atan2(vbeta,valpha);\n"
"\n"
"\n"
"\n"
"\n"
"if (-pi/6 <= theta && theta < pi/6) n=1;\n"
"if (pi/6 <= theta && theta < pi/2) n=2;\n"
"if (pi/2 <= theta && theta < 5*pi/6) n=3;\n"
"if (5*pi/6 <= theta && theta < pi) n=4;\n"
"if (-pi <= theta && theta < -5*pi/6) n=4;\n"
"if (-5*pi/6 <= theta && theta < -pi/2) n=5;\n"
"if (-pi/2 <= theta && theta < -pi/6) n=6;\n"
"\n"
"phi=theta;\n"
"m=1;\n"
"ty=1/3.0-(1/3.0)*m*(2/sqrt(3))*cos(phi);\n"
"tz=1/3.0+(1/3.0)*m*(2/sqrt(3))*sin(-phi+pi/6.0);\n"
"tx=1-ty-tz;\n"
"\n"
"if(n==1)\n"
"{\n"
"x= fmax(-3*ty, 3*tz/2.0-3/2.0) ;\n"
"y= fmax(x,3*tx/2.0-3/2.0);\n"
"tx1=tx-(2/3.0)*y;\n"
"ty1=ty+y/3.0;\n"
"tz1=tz-(2/3.0)*y;\n"
"\n"
"vau=tz1+y;\n"
"vad=ty1+tz1+y;\n"
"vbu=1;\n"
"vbd=tz1+y;\n"
"vcu=ty1+tz1+y;\n"
"vcd=y;\n"
"}\n"
"\n"
"if(n==3)\n"
"{\n"
"x= fmax(-3*tz, 3*ty/2.0-3/2.0);\n"
"y= fmax(x,3*tx/2.0-3/2.0);\n"
"tx1=tx-(2/3.0)*y;\n"
"ty1=ty+y/3.0;\n"
"tz1=tz-(2/3.0)*y;\n"
"\n"
"vau=tz1;\n"
"vad=ty1+tz1+y;\n"
"vbu=1;\n"
"vbd=tz1;\n"
"vcu=ty1+tz1;\n"
"vcd=0;\n"
"}\n"
"\n"
"if(n==5)\n"
"{\n"
"x= fmax(-3*tx, 3*tz/2.0-3/2.0);\n"
"y= fmax(x, 3*ty/2.0-3/2.0);\n"
"tx1=tx-(2/3.0)*y;\n"
"ty1=ty+y/3.0;\n"
"tz1=tz-(2/3.0)*y;\n"
"\n"
"vau=tz1;\n"
"vad=ty1+tz1+y;\n"
"vbu=1;\n"
"vbd=tz1+y;\n"
"vcu=ty1+tz1+y;\n"
"vcd=0;\n"
"}\n"
"\n"
"if(n==2||n==4||n==6)\n"
"{\n"
"y=0.00;\n"
"tx1=tx-(2/3.0)*y;\n"
"ty1=ty+y/3.0;\n"
"tz1=tz-(2/3.0)*y;\n"
"\n"
"\n"
"vau=tz1+y;\n"
"vad=ty1+tz1+y;\n"
"vbu=1;\n"
"vbd=tz1+y;\n"
"vcu=ty1+tz1+y;\n"
"vcd=y;\n"
"}\n"
"\n"
"OutputSignal(0, 0)=phi;\n"
"OutputSignal(0, 1)=vau;\n"
"OutputSignal(0, 2)=vad;\n"
"OutputSignal(0, 3)=vbu;\n"
"OutputSignal(0, 4)=vbd;\n"
"OutputSignal(0, 5)=vcu;\n"
"OutputSignal(0, 6)=vcd;"
        Show          off
      }
